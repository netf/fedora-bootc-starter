# Authoritative installer template for bootc-image-builder.
# Render with scripts/render-installer-config.sh before use.

[customizations.installer.kickstart]
contents = """
text
keyboard --xlayouts='pl'
lang en_GB.UTF-8
timezone Europe/Warsaw --utc

network --bootproto=dhcp --device=link --activate --hostname=fw13

zerombr
clearpart --all --initlabel --disklabel=gpt
reqpart --add-boot
part / --grow --fstype=btrfs --encrypted --luks-version=luks2 --pbkdf=argon2id --passphrase={{INSTALL_LUKS_PASSPHRASE}}

rootpw --lock
user --name=netf --groups=wheel --iscrypted --password='{{ADMIN_PASSWORD_HASH}}'

services --enabled=sshd,tailscaled
firstboot --disable
reboot --eject
"""

[customizations.installer.modules]
disable = ["org.fedoraproject.Anaconda.Modules.Users"]

{{EXTRA_USER_BLOCKS}}
[customizations.kernel]
append = "{{EXTRA_KERNEL_APPEND}}"

[customizations.iso]
volume_id = "FEDORA-BOOTC-STARTER"
